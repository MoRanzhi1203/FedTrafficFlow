{
  "environment": {
    "python_path": "E:\\anaconda3\\envs\\analysis\\python.exe",
    "python_target": "3.9"
  },
  "input": {
    "input_dir": "data/analysis/node_intersection_flow_parquet",
    "output_dir": "results/real_data_missingness_full_intersection_causal_history_hybridtest_small",
    "input_pattern": "node_flow_chunk_*.parquet",
    "mechanism": "mcar_point",
    "missing_rates": [
      0.05
    ],
    "seed": [
      42
    ],
    "impute_methods": [
      "zero_fill",
      "forward_fill",
      "historical_linear_extrapolation",
      "geo_neighbor_fill",
      "function_curve_fit",
      "geo_func_hybrid"
    ]
  },
  "causal_checks": {
    "causal_history_only": true,
    "history_days": 7,
    "context_days_after": 0,
    "uses_future_days": false,
    "uses_same_day_future_slots": false,
    "uses_bfill": false,
    "uses_bidirectional_interpolation": false,
    "warmup_days": 7,
    "main_metrics_exclude_warmup": true,
    "allow_current_day_past": true
  },
  "time_index_construction": {
    "formula": "global_time_index = day_index * 96 + time_slot",
    "period": 96,
    "chunk_records": [
      {
        "day_index": 0,
        "file_name": "node_flow_chunk_000.parquet",
        "file_path": "data/analysis/node_intersection_flow_parquet/node_flow_chunk_000.parquet",
        "rows_used": 200,
        "node_count": 200,
        "time_slot_count": 1,
        "time_slot_min": 0,
        "time_slot_max": 0,
        "warmup": true
      }
    ]
  },
  "summary_rows": {
    "all_days": 1,
    "exclude_warmup": 0
  }
}